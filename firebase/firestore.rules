rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: anyone signed-in can read, only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // MATCHES: only participants can read; only Cloud Functions create
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        (resource.data.userA == request.auth.uid ||
         resource.data.userB == request.auth.uid);
      allow create: if false;
      allow update: if request.auth != null &&
        (resource.data.userA == request.auth.uid ||
         resource.data.userB == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['unreadCountA', 'unreadCountB']);
      allow delete: if false;
    }

    // MESSAGES: participants only, text-only, max 1000 chars
    match /chats/{matchId}/messages/{messageId} {
      allow read: if request.auth != null && isParticipant(matchId);
      allow create: if request.auth != null &&
        isParticipant(matchId) &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['senderId','text','createdAt','readAt']) &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 1000 &&
        request.resource.data.readAt == null;
      allow update: if request.auth != null &&
        isParticipant(matchId) &&
        request.auth.uid != resource.data.senderId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow delete: if false;
    }

    // MATCH HISTORY: only owner can read; Cloud Functions write via admin SDK
    match /matchHistory/{userId}/weeks/{weekId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    function isParticipant(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId));
      return m.data.userA == request.auth.uid || m.data.userB == request.auth.uid;
    }
  }
}
